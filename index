<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alora Macedon – Request for Tender</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #e9ecef;
            font-family: 'Segoe UI', Roboto, Arial, sans-serif;
            line-height: 1.5;
            padding: 2rem 1rem;
            color: #1e2a3a;
        }
        .tender-container {
            max-width: 1100px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
            padding: 2rem 2rem 3rem;
        }
        h1, h2, h3 {
            margin-top: 1.5em;
            margin-bottom: 0.5em;
            font-weight: 600;
        }
        h1 {
            font-size: 1.9rem;
            margin-top: 0;
            color: #0b3b2f;
            border-left: 5px solid #2c7a4d;
            padding-left: 1rem;
        }
        h2 {
            font-size: 1.5rem;
            border-bottom: 2px solid #dee2e6;
            padding-bottom: 0.3rem;
        }
        hr {
            margin: 1.5rem 0;
        }
        .section {
            margin: 2rem 0;
        }
        .sub-section {
            margin: 1.2rem 0;
        }
        ul, .checklist {
            margin: 0.75rem 0 0.75rem 1.5rem;
        }
        .checkbox-group {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin: 0.5rem 0 1rem;
        }
        .checkbox-group label {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: #f8f9fa;
            padding: 0.3rem 0.8rem;
            border-radius: 30px;
            border: 1px solid #ced4da;
        }
        input[type="checkbox"], input[type="radio"] {
            width: 1.1em;
            height: 1.1em;
        }
        textarea, input[type="text"], input[type="email"] {
            width: 100%;
            padding: 0.6rem;
            border: 1px solid #adb5bd;
            border-radius: 8px;
            font-family: inherit;
            font-size: 0.9rem;
            margin-top: 0.3rem;
        }
        textarea {
            min-height: 80px;
            resize: vertical;
        }
        .qa-block {
            background: #fef9e6;
            border-left: 4px solid #e9b741;
            padding: 1rem 1.2rem;
            margin: 1rem 0;
            border-radius: 10px;
        }
        .declaration {
            background: #f1f3f5;
            padding: 1.2rem;
            border-radius: 12px;
            margin-top: 2rem;
        }
        .sign-line {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5rem;
            margin-top: 1rem;
        }
        .sign-field {
            flex: 1;
            min-width: 180px;
        }
        button {
            background: #2c7a4d;
            color: white;
            border: none;
            padding: 0.8rem 1.8rem;
            font-size: 1rem;
            border-radius: 40px;
            cursor: pointer;
            font-weight: 600;
            margin-top: 1.5rem;
            transition: background 0.2s;
        }
        button:hover {
            background: #1e5a3a;
        }
        .print-button {
            background: #495057;
            margin-right: 1rem;
        }
        .footer-note {
            margin-top: 2rem;
            font-size: 0.8rem;
            text-align: center;
            color: #6c757d;
            border-top: 1px solid #dee2e6;
            padding-top: 1.5rem;
        }
        @media (max-width: 700px) {
            .tender-container {
                padding: 1.2rem;
            }
        }
        @media print {
            body {
                background: white;
                padding: 0;
            }
            .tender-container {
                box-shadow: none;
                padding: 0;
                max-width: 100%;
            }
            button {
                display: none;
            }
            input, textarea {
                border: 1px solid #000;
                background: transparent;
            }
        }
    </style>
</head>
<body>
<div class="tender-container">
    <h1>REQUEST FOR TENDER (RFT)<br>ALORA MACEDON – VENUE OPERATIONS & MANAGEMENT SERVICES</h1>
    <p><strong>Issued by:</strong> Stephanie Reade, Owner<br>
    <strong>Venue:</strong> Alora Macedon<br>
    <strong>Date:</strong> <input type="text" placeholder="Enter date" style="width: auto; display: inline-block; width: 150px;"></p>

    <!-- Section 1: Introduction -->
    <div class="section">
        <h2>1. INTRODUCTION</h2>
        <p>Alora Macedon is a function centre with a beautiful event space, three guest accommodations, a pool, extensive grounds, and a separate ceremony shed located a distance from the main hall. We host weddings, corporate events, and private functions.</p>
        <p>We are seeking a dedicated person or team to manage the day‑to‑day operations, maintenance, and event support. This is a critical role because we have a tight turnaround between events: guests check out at 10:00 am, and the next event arrives at 12:00 pm. We need a reliable, honest, and capable person who can either perform the work themselves or coordinate a team of subcontractors.</p>
        <p>This document outlines our requirements. Please read it carefully and respond with your proposal, answering all questions in Section 6.</p>
    </div>

    <!-- Section 2: Venue overview -->
    <div class="section">
        <h2>2. THE VENUE – QUICK OVERVIEW</h2>
        <ul>
            <li>Main function hall</li>
            <li>Separate ceremony shed (located a distance from the main hall)</li>
            <li>Three guest accommodations (each with bedrooms, bathrooms, living areas)</li>
            <li>Outdoor pool</li>
            <li>Gardens and grounds (including the area between the shed and main hall)</li>
            <li>Kitchen facilities (used by caterers)</li>
            <li>No commercial truck access for waste – bins must be moved by caddy to roadside</li>
        </ul>
    </div>

    <!-- Section 3: Staffing models -->
    <div class="section">
        <h2>3. WHAT WE ARE LOOKING FOR</h2>
        <p>We are open to different staffing models. You can propose:</p>
        <div class="checkbox-group">
            <label><input type="checkbox"> A single, multi‑skilled caretaker who lives on‑site (or nearby) and handles most tasks personally.</label>
            <label><input type="checkbox"> A husband‑and‑wife or small team who together cover all services.</label>
            <label><input type="checkbox"> A manager who coordinates a network of trusted subcontractors (cleaners, gardeners, waste removal, etc.).</label>
            <label><input type="checkbox"> A hybrid: on‑site caretaker who does some tasks and subcontracts specialist work.</label>
        </div>
        <p>Whichever model you propose, we need one main contact person who takes responsibility for ensuring everything is done to our standards.</p>
    </div>

    <!-- Section 4: Scope of work (condensed for brevity; full content from original) -->
    <div class="section">
        <h2>4. SCOPE OF WORK – WHAT NEEDS TO BE DONE</h2>
        <p>Below is the full list of services we require. In your proposal, tell us which services you will personally provide, and which (if any) you will subcontract.</p>
        <!-- I'll include all service items to keep complete, but to save space I'll list them with brief bullets as in original tender -->
        <div class="sub-section"><strong>A. CLEANING & TURNAROUND (Critical)</strong> – Clean 3 accommodations, main hall, ceremony shed within 10am‑12pm; simultaneous cleaning due to distance; handle sudden repairs.</div>
        <div class="sub-section"><strong>B. WASTE & RECYCLING LOGISTICS</strong> – Manage caddy system; general waste, recycling, cardboard; roadside placement.</div>
        <div class="sub-section"><strong>C. GARDENING & GROUNDS</strong> – Mowing, edging, weed control; pathways between shed and hall.</div>
        <div class="sub-section"><strong>D. POOL MAINTENANCE</strong> – Chemical balance, cleaning, equipment checks.</div>
        <div class="sub-section"><strong>E. EVENT SUPPORT</strong> – Open/close venue; bump‑in/out; during‑event support; coordinate suppliers.</div>
        <div class="sub-section"><strong>F. HANDYMAN & MINOR REPAIRS</strong> – Small fixes; arrange specialists for larger issues.</div>
        <div class="sub-section"><strong>G. COMPLIANCE & SAFETY</strong> – Test & tag; fire safety; emergency management (marshalling area, megaphone/walkie‑talkie, drills); non‑slip surfaces.</div>
        <div class="sub-section"><strong>H. SUPPLIER INSURANCE & RECORD KEEPING</strong> – Collect public liability certificates; maintain per‑event file.</div>
        <div class="sub-section"><strong>I. ACCESS & SECURITY</strong> – Manage remote disarm, pre‑access codes, fobs; on‑site supplier coordination.</div>
        <div class="sub-section"><strong>J. KITCHEN & FOOD SAFETY</strong> – Ensure caterers follow food safety; integrate kitchen into emergency plans.</div>
    </div>

    <!-- Section 5: What to provide -->
    <div class="section">
        <h2>5. WHAT YOU NEED TO PROVIDE IN YOUR TENDER</h2>
        <ol style="margin-left: 1.5rem;">
            <li>Your preferred staffing model: <input type="text" placeholder="Describe or tick above" style="width: 300px;"></li>
            <li>Description of how you will deliver services, especially across two buildings.</li>
            <li>Relevant experience.</li>
            <li>Availability (weekends, 10am‑12pm window).</li>
            <li>Fee structure.</li>
            <li>Answers to Section 6 questionnaire.</li>
        </ol>
        <textarea rows="3" placeholder="Use this space to describe your plan, experience, availability, and fee structure..."></textarea>
    </div>

    <!-- Section 6: Questionnaire -->
    <div class="section">
        <h2>6. APPLICANT QUESTIONNAIRE (MUST BE COMPLETED)</h2>
        <div class="qa-block">
            <p>Q1. How would you handle the 10:00 am – 12:00 pm turnover with three accommodations, main hall, and ceremony shed? Describe process, number of people, and how you handle last‑minute repairs.</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q2. Waste trucks cannot access the venue. How would you manage waste, recycling, and cardboard after a large wedding using caddy system?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q3. Experience with emergency management? How would you keep Alora Macedon ready for an emergency (marshalling, alarms, megaphone/walkie‑talkie, drills) considering two buildings?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q4. How would you ensure every supplier has current public liability insurance? Describe your system for collecting and filing certificates.</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q5. Manage remote disarm, pre‑access codes, and fobs across both buildings. How do you keep access secure while letting suppliers in?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q6. Approach to gardening and grounds? Do you have own equipment? How do you maintain pathways between shed and main hall?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q7. Handle unexpected maintenance issues (broken pipe, faulty lock) during event or before arrival, especially if issue is in one building while you're in another?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q8. Previous experience with function centres, weddings, or multiple‑building venues? Biggest challenge overcome?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q9. Availability for weekends and flexible hours? Any restrictions?</p>
            <textarea rows="3"></textarea>
        </div>
        <div class="qa-block">
            <p>Q10. Anything else you'd like us to know about your skills or work style?</p>
            <textarea rows="3"></textarea>
        </div>
    </div>

    <!-- Section 7: Submission -->
    <div class="section">
        <h2>7. HOW TO SUBMIT YOUR TENDER</h2>
        <p>Please email your completed tender (including your proposal and answers to the questionnaire) to:</p>
        <p><strong>Stephanie Reade</strong><br>
        Email: <input type="email" placeholder="recipient email (optional)"> <br>
        Phone: <input type="text" placeholder="Your phone"> <br>
        Submission deadline: <input type="text" placeholder="DD/MM/YYYY"></p>
    </div>

    <!-- Section 8: Declaration -->
    <div class="declaration">
        <h2>8. DECLARATION</h2>
        <p>By submitting this tender, I/we declare that the information provided is true and correct. I/we understand that Alora Macedon may verify references and insurance details.</p>
        <div class="sign-line">
            <div class="sign-field"><label>Name:</label><input type="text" placeholder="Full name"></div>
            <div class="sign-field"><label>Signature:</label><input type="text" placeholder="Sign or type name"></div>
            <div class="sign-field"><label>Date:</label><input type="text" placeholder="DD/MM/YYYY"></div>
        </div>
    </div>

    <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 2rem;">
        <button class="print-button" onclick="window.print();">🖨️ Print / Save as PDF</button>
        <button onclick="generateEmailSummary();">📧 Prepare for Email</button>
    </div>
    <div class="footer-note">
        Alora Macedon – Request for Tender | Complete and return by deadline.
    </div>
</div>

<script>
function generateEmailSummary() {
    // Collect all textarea answers and key fields into a plain text summary
    let summary = "ALORA MACEDON TENDER SUBMISSION\n";
    summary += "--------------------------------\n\n";

    // Get main text fields
    const dateInput = document.querySelector('.tender-container input[placeholder="Enter date"]');
    if (dateInput && dateInput.value) summary += "Date: " + dateInput.value + "\n\n";

    const modelDesc = document.querySelector('.section ol li input[type="text"]');
    if (modelDesc && modelDesc.value) summary += "Staffing model: " + modelDesc.value + "\n\n";

    const planTextarea = document.querySelector('.section textarea[placeholder*="plan"]');
    if (planTextarea && planTextarea.value) summary += "Your plan / experience / fee structure:\n" + planTextarea.value + "\n\n";

    // Questionnaire answers
    const qBlocks = document.querySelectorAll('.qa-block');
    let qNum = 1;
    qBlocks.forEach(block => {
        const textarea = block.querySelector('textarea');
        if (textarea && textarea.value.trim() !== "") {
            summary += `Q${qNum}: ${textarea.value.trim()}\n\n`;
        }
        qNum++;
    });

    // Declaration fields
    const nameField = document.querySelector('.sign-field input[placeholder="Full name"]');
    const sigField = document.querySelector('.sign-field input[placeholder="Sign or type name"]');
    const decDateField = document.querySelector('.sign-field input[placeholder="DD/MM/YYYY"]');
    if (nameField && nameField.value) summary += "Name: " + nameField.value + "\n";
    if (sigField && sigField.value) summary += "Signature: " + sigField.value + "\n";
    if (decDateField && decDateField.value) summary += "Date: " + decDateField.value + "\n";

    // Show summary in a modal or alert
    const emailBody = encodeURIComponent(summary);
    window.location.href = "mailto:?subject=Alora Macedon Tender Submission&body=" + emailBody;
}
</script>
</body>
</html>