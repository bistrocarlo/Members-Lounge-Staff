import React, { useEffect, useState } from 'react';
import { Container, Typography, List, ListItem, ListItemText, Switch, CircularProgress, Box, Alert } from '@mui/material';
import api from '../services/api';

interface Event {
  id: string;
  date: string;
  venue_name: string;
}

const Events: React.FC = () =&gt; {
  const [events, setEvents] = useState&lt;Event[]&gt;([]);
  const [availability, setAvailability] = useState&lt;Record&lt;string, boolean&gt;&gt;({});
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');

  useEffect(() =&gt; {
    const fetchData = async () =&gt; {
      try {
        const [eventsRes, availRes] = await Promise.all([
          api.get('/events'),
          api.get('/availability'),
        ]);
        setEvents(eventsRes.data);
        const availMap: Record&lt;string, boolean&gt; = {};
        availRes.data.forEach((a: any) =&gt; {
          availMap[a.event_id] = a.is_available;
        });
        setAvailability(availMap);
      } catch (err) {
        setError('Failed to load events');
      } finally {
        setLoading(false);
      }
    };
    fetchData();
  }, []);

  const handleToggle = async (eventId: string, checked: boolean) =&gt; {
    setAvailability(prev =&gt; ({ ...prev, [eventId]: checked }));
    try {
      await api.put('/availability', { eventId, isAvailable: checked });
    } catch (err) {
      setError('Failed to update availability');
      setAvailability(prev =&gt; ({ ...prev, [eventId]: !checked }));
    }
  };

  if (loading) return &lt;CircularProgress sx={{ display: 'block', mx: 'auto', mt: 4 }} /&gt;;

  return (
    &lt;Container&gt;
      &lt;Typography variant="h4" gutterBottom&gt;Upcoming Events&lt;/Typography&gt;
      {error && &lt;Alert severity="error" sx={{ mb: 2 }}&gt;{error}&lt;/Alert&gt;}
      &lt;List&gt;
        {events.map((event) =&gt; (
          &lt;ListItem
            key={event.id}
            secondaryAction={
              &lt;Switch
                edge="end"
                checked={availability[event.id] || false}
                onChange={(e) =&gt; handleToggle(event.id, e.target.checked)}
                color="primary"
              /&gt;
            }
          &gt;
            &lt;ListItemText
              primary={`${new Date(event.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })} — ${event.venue_name}`}
            /&gt;
          &lt;/ListItem&gt;
        ))}
      &lt;/List&gt;
    &lt;/Container&gt;
  );
};

export default Events;
    </pre>

