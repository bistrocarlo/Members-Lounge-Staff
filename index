  if (!req.user.is_admin && req.user.id !== req.params.id) {
    return res.status(403).json({ message: 'Forbidden' });
  }
  const { full_name, phone, roles } = req.body;
  try {
    const result = await query(
      'UPDATE users SET full_name = $1, phone = $2, roles = $3 WHERE id = $4 RETURNING id, email, full_name, phone, roles, is_admin',
