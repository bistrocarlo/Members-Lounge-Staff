import { Router } from 'express';
import { query } from '../db';
import { authenticate, requireAdmin, AuthRequest } from '../middleware/auth';

const router = Router();

// Get all users (admin only)
router.get('/', authenticate, requireAdmin, async (req, res) => {
  const result = await query(
    'SELECT id, email, full_name, phone, roles, is_active, is_admin FROM users ORDER BY full_name'
  );
  res.json(result.rows);
});

// Get single user (admin or self)
router.get('/:id', authenticate, async (req: AuthRequest, res) => {
  if (!req.user.is_admin && req.user.id !== req.params.id) {
    return res.status(403).json({ message: 'Forbidden' });
  }
  const result = await query(
    'SELECT id, email, full_name, phone, roles, is_active, is_admin FROM users WHERE id = $1',
    [req.params.id]
  );
  if (result.rows.length === 0) return res.status(404).json({ message: 'User not found' });
  res.json(result.rows[0]);
});

// Update user (admin or self)
router.put('/:id', authenticate, async (req: AuthRequest, res) => {
  if (!req.user.is_admin && req.user.id !== req.params.id) {
    return res.status(403).json({ message: 'Forbidden' });
  }
  const { full_name, phone, roles } = req.body;
  try {
    const result = await query(
      'UPDATE users SET full_name = $1, phone = $2, roles = $3 WHERE id = $4 RETURNING id, email, full_name, phone, roles, is_admin',
      [full_name, phone, roles, req.params.id]
    );
    res.json(result.rows[0]);
  } catch (err) {
    console.error(err);
    res.status(500).json({ message: 'Server error' });
  }
});

// Deactivate/activate (admin only)
router.patch('/:id/toggle-active', authenticate, requireAdmin, async (req, res) => {
  const user = await query('SELECT is_active FROM users WHERE id = $1', [req.params.id]);
  if (user.rows.length === 0) return res.status(404).json({ message: 'User not found' });
  const newStatus = !user.rows[0].is_active;
  await query('UPDATE users SET is_active = $1 WHERE id = $2', [newStatus, req.params.id]);
  res.json({ message: `User ${newStatus ? 'activated' : 'deactivated'}` });
});

export default router;
    </pre>

