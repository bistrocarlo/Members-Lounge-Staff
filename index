            font-weight: 700;
            letter-spacing: 0.5px;
        }

        h2 {
            font-size: 2rem;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid #d4af37;
            display: inline-block;
            padding-bottom: 0.25rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1rem;
            width: 100%;
            flex: 1;
        }

        /* Language switcher */
        .lang-switcher {
            display: flex;
            justify-content: flex-end;
            gap: 1rem;
            margin: 1rem 0;
        }
        .lang-btn {
            background: transparent;
            border: 1px solid #d4af37;
            color: #000;
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 600;
            padding: 0.4rem 1.2rem;
            cursor: pointer;
            border-radius: 30px;
            transition: all 0.3s;
        }
        .lang-btn.active {
            background: #d4af37;
            color: #000;
            border-color: #d4af37;
        }
        .lang-btn:hover {
            background: #d4af37;
            color: #000;
        }

        /* Navigation */
        .nav {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin: 2rem 0 1rem;
            flex-wrap: wrap;
        }

        .nav-btn {
            background: transparent;
            border: none;
            color: #000;
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 600;
            padding: 0.5rem 1.5rem;
            cursor: pointer;
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
            letter-spacing: 1px;
        }

        .nav-btn.active {
            border-bottom-color: #d4af37;
            color: #d4af37;
        }

        .nav-btn:hover {
            color: #d4af37;
        }

        /* Sections */
        .section {
            display: none;
            animation: fade 0.3s ease;
        }

        .section.active {
            display: block;
        }

        @keyframes fade {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Cards */
        .card {
            background: #f9f9f9;
            border: 1px solid #e0e0e0;
            border-radius: 12px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        }

        .service-item {
            margin-bottom: 1.5rem;
        }

        .service-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: #d4af37;
            margin-bottom: 0.25rem;
        }

        .price-tag {
            font-size: 2.5rem;
            font-weight: 700;
            color: #d4af37;
            font-family: 'Playfair Display', serif;
            line-height: 1.2;
        }

        .price-note {
            font-size: 1rem;
            color: #555;
            margin-top: 0.5rem;
        }

        .contact-info {
            background: #f9f9f9;
            padding: 2rem;
            border-radius: 12px;
            border-left: 6px solid #d4af37;
        }

        .contact-phone {
            font-size: 1.8rem;
            font-weight: 600;
            font-family: 'Playfair Display', serif;
            color: #000;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 1rem;
        }
        .contact-phone:hover {
            color: #d4af37;
        }
        .contact-email {
            color: #000;
            text-decoration: none;
            border-bottom: 1px solid #d4af37;
            font-weight: 500;
            font-size: 1.2rem;
            word-break: break-all;
        }
        .contact-email:hover {
            color: #d4af37;
        }

        /* Forms */
        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            font-family: 'Playfair Display', serif;
            font-weight: 600;
            color: #d4af37;
            margin-bottom: 0.5rem;
            font-size: 1.1rem;
        }

        input, textarea, select {
            width: 100%;
            padding: 1rem;
            background: #fff;
            border: 1px solid #ccc;
            color: #000;
            border-radius: 8px;
            font-family: 'Montserrat', sans-serif;
            font-size: 1rem;
            font-weight: 400;
            transition: border 0.3s;
        }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #d4af37;
        }

        textarea {
            min-height: 100px;
            resize: vertical;
        }

        select {
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23d4af37' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
            background-repeat: no-repeat;
            background-position: right 1rem center;
            background-size: 1.2rem;
        }

        .btn {
            background: #d4af37;
            color: #000;
            border: none;
            padding: 1rem 2.5rem;
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem;
            font-weight: 700;
            border-radius: 40px;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 1rem;
            border: 1px solid #d4af37;
        }

        .btn:hover {
            background: transparent;
            color: #d4af37;
        }

        .btn-outline {
            background: transparent;
            color: #000;
            border: 1px solid #d4af37;
            margin-left: 1rem;
        }
        .btn-outline:hover {
            background: #d4af37;
            color: #000;
        }

        .btn-add {
            background: transparent;
            color: #d4af37;
            border: 1px dashed #d4af37;
            padding: 0.5rem 1rem;
            font-size: 1rem;
            border-radius: 30px;
            margin-bottom: 1rem;
            cursor: pointer;
        }
        .btn-add:hover {
            background: #d4af37;
            color: #000;
        }

        .footer {
            text-align: center;
            padding: 2rem 1rem;
            border-top: 1px solid #eee;
            margin-top: 3rem;
            color: #666;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }

        .paired-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
            align-items: center;
        }

        @media (max-width: 640px) {
            .grid-2, .grid-3, .paired-row {
                grid-template-columns: 1fr;
            }
            h2 {
                font-size: 1.6rem;
            }
            .nav-btn {
                font-size: 1rem;
                padding: 0.5rem 1rem;
            }
            .price-tag {
                font-size: 2rem;
            }
        }

        /* Gold border accents */
        .gold-border {
            border: 1px solid #d4af37;
        }

        .gold-bottom {
            border-bottom: 2px solid #d4af37;
        }

        /* Saved indicator */
        .saved-msg {
            color: #d4af37;
            font-size: 0.9rem;
            margin-top: 0.5rem;
            text-align: right;
            font-style: italic;
        }

        /* Radio/checkbox styling */
        .radio-group {
            display: flex;
            gap: 2rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .radio-option {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .radio-option input[type="radio"] {
            width: auto;
            accent-color: #d4af37;
        }

        /* Print styles */
        @media print {
            body { background: white; }
            .no-print, .nav, .lang-switcher, .btn, .footer, .nav-btn, .saved-msg { display: none !important; }
            .section { display: block !important; }
            .card { border: 1px solid #d4af37; break-inside: avoid; }
            h2 { color: #000; border-bottom-color: #d4af37; }
        }

        /* Summary page for print */
        #print-summary {
            display: none;
        }
        @media print {
            #print-summary {
                display: block;
            }
            .no-print, .nav, .lang-switcher, .btn, .footer, .nav-btn, .saved-msg { display: none !important; }
            .section { display: none !important; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Language switcher -->
        <div class="lang-switcher no-print">
            <button class="lang-btn active" id="lang-en">EN</button>
