// Get all assignments for an event (admin only)
router.get('/event/:eventId', authenticate, requireAdmin, async (req, res) => {
  const result = await query(
    `SELECT a.user_id, u.full_name, u.roles, a.role
     FROM assignments a
     JOIN users u ON a.user_id = u.id
     WHERE a.event_id = $1`,
    [req.params.eventId]
  );
  res.json(result.rows);
});

// Create assignment (admin only) – includes conflict check
router.post('/', authenticate, requireAdmin, async (req, res) => {
  const { eventId, userId, role } = req.body;

  // Check if user is already assigned to another event on the same day
  const conflictCheck = await query(
    `SELECT e.date FROM events e
     JOIN assignments a ON e.id = a.event_id
     WHERE a.user_id = $1 AND e.id != $2 AND e.date = (
       SELECT date FROM events WHERE id = $2
     )`,
    [userId, eventId]
  );

  if (conflictCheck.rows.length > 0) {
    return res.status(409).json({ message: 'User already assigned to another event on this date' });
  }

  try {
    const result = await query(
      'INSERT INTO assignments (event_id, user_id, role) VALUES ($1, $2, $3) RETURNING *',
      [eventId, userId, role]
    );
    res.status(201).json(result.rows[0]);
  } catch (err: any) {
    if (err.code === '23505') {
      return res.status(409).json({ message: 'User already assigned to this event' });
    }
    console.error(err);
    res.status(500).json({ message: 'Server error' });
  }
});

// Remove assignment (admin only)
router.delete('/:id', authenticate, requireAdmin, async (req, res) => {
  const result = await query('DELETE FROM assignments WHERE id = $1 RETURNING id', [req.params.id]);
  if (result.rows.length === 0) return res.status(404).json({ message: 'Assignment not found' });
