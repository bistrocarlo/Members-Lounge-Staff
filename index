    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #ffffff;
            color: #000000;
            font-family: 'Montserrat', sans-serif;
            font-weight: 400;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .gold {
            color: #d4af37;
        }

        .bg-gold {
            background-color: #d4af37;
            color: #000;
        }

        h1, h2, h3, h4 {
