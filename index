    <script>
        (function() {
            let currentLang = 'en';

            // Language switcher
            const langEn = document.getElementById('lang-en');
            const langEl = document.getElementById('lang-el');
            const langBtns = [langEn, langEl];

            function setLanguage(lang) {
                currentLang = lang;
                langBtns.forEach(btn => btn.classList.remove('active'));
                if (lang === 'en') langEn.classList.add('active');
                else langEl.classList.add('active');

                document.querySelectorAll('[data-en]').forEach(el => {
                    if (el.tagName === 'OPTION') {
                        el.textContent = el.getAttribute(`data-${lang}`) || el.textContent;
                    } else {
                        el.textContent = el.getAttribute(`data-${lang}`) || el.textContent;
                    }
                });
            }

            langEn.addEventListener('click', () => setLanguage('en'));
            langEl.addEventListener('click', () => setLanguage('el'));

            // Navigation
            const btnHome = document.getElementById('btn-home');
            const btnParty = document.getElementById('btn-party');
            const btnJournal = document.getElementById('btn-journal');
            const homeSection = document.getElementById('home-section');
            const partySection = document.getElementById('party-section');
            const journalSection = document.getElementById('journal-section');
            const navBtns = [btnHome, btnParty, btnJournal];

            function showSection(sectionToShow) {
                homeSection.classList.remove('active');
                partySection.classList.remove('active');
                journalSection.classList.remove('active');
                sectionToShow.classList.add('active');
                navBtns.forEach(btn => btn.classList.remove('active'));
                if (sectionToShow === homeSection) btnHome.classList.add('active');
                if (sectionToShow === partySection) btnParty.classList.add('active');
                if (sectionToShow === journalSection) btnJournal.classList.add('active');
            }

            btnHome.addEventListener('click', () => showSection(homeSection));
            btnParty.addEventListener('click', () => showSection(partySection));
            btnJournal.addEventListener('click', () => showSection(journalSection));

            // Dynamic pairs for bridal party
            const bridalContainer = document.getElementById('bridal-pairs-container');
            const addBridalBtn = document.getElementById('add-bridal-pair');

            function createBridalPair(person1 = '', person2 = '') {
                const pairDiv = document.createElement('div');
                pairDiv.className = 'paired-row';
                pairDiv.innerHTML = `
                    <div class="form-group">
                        <label data-en="Person 1" data-el="Άτομο 1">Person 1</label>
                        <input type="text" class="bridal-person1" value="${person1}" placeholder="Full name">
                    </div>
                    <div class="form-group">
                        <label data-en="Person 2" data-el="Άτομο 2">Person 2</label>
                        <input type="text" class="bridal-person2" value="${person2}" placeholder="Full name">
                    </div>
                `;
                return pairDiv;
            }

            function loadBridalPairs(pairs) {
                bridalContainer.innerHTML = ''; // clear existing
                if (pairs && pairs.length) {
                    pairs.forEach(p => {
                        bridalContainer.appendChild(createBridalPair(p.person1, p.person2));
                    });
                } else {
                    // default one empty pair
                    bridalContainer.appendChild(createBridalPair('', ''));
                }
            }

            function getBridalPairs() {
                const pairs = [];
                const rows = bridalContainer.querySelectorAll('.paired-row');
                rows.forEach(row => {
                    const person1 = row.querySelector('.bridal-person1')?.value || '';
                    const person2 = row.querySelector('.bridal-person2')?.value || '';
                    pairs.push({ person1, person2 });
                });
                return pairs;
            }

            addBridalBtn.addEventListener('click', () => {
                bridalContainer.appendChild(createBridalPair('', ''));
            });

            // Dynamic pairs for flower kids
            const flowerContainer = document.getElementById('flower-pairs-container');
            const addFlowerBtn = document.getElementById('add-flower-pair');

            function createFlowerPair(person1 = '', person2 = '') {
                const pairDiv = document.createElement('div');
                pairDiv.className = 'paired-row';
                pairDiv.innerHTML = `
                    <div class="form-group">
                        <label data-en="Flower Kid 1" data-el="Παιδί 1">Flower Kid 1</label>
                        <input type="text" class="flower-person1" value="${person1}" placeholder="Full name">
                    </div>
                    <div class="form-group">
                        <label data-en="Flower Kid 2" data-el="Παιδί 2">Flower Kid 2</label>
                        <input type="text" class="flower-person2" value="${person2}" placeholder="Full name">
                    </div>
                `;
                return pairDiv;
            }

            function loadFlowerPairs(pairs) {
                flowerContainer.innerHTML = ''; // clear existing
                if (pairs && pairs.length) {
                    pairs.forEach(p => {
                        flowerContainer.appendChild(createFlowerPair(p.person1, p.person2));
                    });
                } else {
                    // default one empty pair
                    flowerContainer.appendChild(createFlowerPair('', ''));
                }
            }

            function getFlowerPairs() {
                const pairs = [];
                const rows = flowerContainer.querySelectorAll('.paired-row');
                rows.forEach(row => {
                    const person1 = row.querySelector('.flower-person1')?.value || '';
                    const person2 = row.querySelector('.flower-person2')?.value || '';
                    pairs.push({ person1, person2 });
                });
                return pairs;
            }

            addFlowerBtn.addEventListener('click', () => {
                flowerContainer.appendChild(createFlowerPair('', ''));
            });

            // Load saved data
            function loadPartyData() {
                const data = JSON.parse(localStorage.getItem('george_mc_party') || '{}');
                document.getElementById('groom').value = data.groom || '';
                document.getElementById('bride').value = data.bride || '';
                document.getElementById('matron').value = data.matron || '';
                document.getElementById('bestman').value = data.bestman || '';
                loadBridalPairs(data.bridalPairs || []);
                loadFlowerPairs(data.flowerPairs || []);
                document.getElementById('parents-groom').value = data.parentsGroom || '';
                document.getElementById('parents-bride').value = data.parentsBride || '';
                document.getElementById('other-people').value = data.otherPeople || '';
            }

            function loadJournalData() {
                const data = JSON.parse(localStorage.getItem('george_mc_journal') || '{}');
                document.getElementById('how-met').value = data.howMet || '';
                document.getElementById('proposal').value = data.proposal || '';
                document.getElementById('traditions').value = data.traditions || '';
                document.getElementById('first-dance').value = data.firstDance || '';
                document.getElementById('other-songs').value = data.otherSongs || '';
                document.getElementById('messages').value = data.messages || '';
                document.getElementById('avoid').value = data.avoid || '';
                // Venue & Team
                document.getElementById('venue-name').value = data.venueName || '';
                document.getElementById('room-name').value = data.roomName || '';
                document.getElementById('wedding-date').value = data.weddingDate || '';
                document.getElementById('dj-name').value = data.djName || '';
                document.getElementById('venue-manager').value = data.venueManager || '';
                document.getElementById('caterer').value = data.caterer || '';
                document.getElementById('activities').value = data.activities || '';
                // Logistics
                document.getElementById('ceremony-time').value = data.ceremonyTime || '';
                document.getElementById('finish-time').value = data.finishTime || '';
                document.getElementById('guest-count').value = data.guestCount || '';
                document.getElementById('wedding-scope').value = data.weddingScope || '';
                document.getElementById('scope-other').value = data.scopeOther || '';
                if (data.houseVisit === 'yes') {
                    document.querySelector('input[name="house-visit"][value="yes"]').checked = true;
                } else {
                    document.querySelector('input[name="house-visit"][value="no"]').checked = true;
                }
                document.getElementById('logistics-notes').value = data.logisticsNotes || '';
            }

            // Save party data
            document.getElementById('save-party').addEventListener('click', function() {
                const bridalPairs = getBridalPairs();
                const flowerPairs = getFlowerPairs();
                const partyData = {
                    groom: document.getElementById('groom').value,
                    bride: document.getElementById('bride').value,
                    matron: document.getElementById('matron').value,
                    bestman: document.getElementById('bestman').value,
                    bridalPairs: bridalPairs,
                    flowerPairs: flowerPairs,
                    parentsGroom: document.getElementById('parents-groom').value,
                    parentsBride: document.getElementById('parents-bride').value,
                    otherPeople: document.getElementById('other-people').value
                };
                localStorage.setItem('george_mc_party', JSON.stringify(partyData));
                document.getElementById('party-saved-msg').innerText = currentLang === 'en' ? '✓ Saved' : '✓ Αποθηκεύτηκε';
                setTimeout(() => document.getElementById('party-saved-msg').innerText = '', 2000);
            });

            // Save journal data
            document.getElementById('save-journal').addEventListener('click', function() {
                const houseVisit = document.querySelector('input[name="house-visit"]:checked')?.value || 'no';
                const journalData = {
                    howMet: document.getElementById('how-met').value,
                    proposal: document.getElementById('proposal').value,
                    traditions: document.getElementById('traditions').value,
                    firstDance: document.getElementById('first-dance').value,
                    otherSongs: document.getElementById('other-songs').value,
                    messages: document.getElementById('messages').value,
                    avoid: document.getElementById('avoid').value,
                    venueName: document.getElementById('venue-name').value,
                    roomName: document.getElementById('room-name').value,
                    weddingDate: document.getElementById('wedding-date').value,
                    djName: document.getElementById('dj-name').value,
                    venueManager: document.getElementById('venue-manager').value,
                    caterer: document.getElementById('caterer').value,
                    activities: document.getElementById('activities').value,
                    ceremonyTime: document.getElementById('ceremony-time').value,
                    finishTime: document.getElementById('finish-time').value,
                    guestCount: document.getElementById('guest-count').value,
                    weddingScope: document.getElementById('wedding-scope').value,
                    scopeOther: document.getElementById('scope-other').value,
                    houseVisit: houseVisit,
                    logisticsNotes: document.getElementById('logistics-notes').value
                };
                localStorage.setItem('george_mc_journal', JSON.stringify(journalData));
                document.getElementById('journal-saved-msg').innerText = currentLang === 'en' ? '✓ Saved' : '✓ Αποθηκεύτηκε';
                setTimeout(() => document.getElementById('journal-saved-msg').innerText = '', 2000);
            });

            // Print function
            document.getElementById('print-btn').addEventListener('click', function() {
                // Populate print summary
                const party = JSON.parse(localStorage.getItem('george_mc_party') || '{}');
                const journal = JSON.parse(localStorage.getItem('george_mc_journal') || '{}');

                let partyHtml = '';
                if (party.groom) partyHtml += `<p><strong>Groom:</strong> ${party.groom}</p>`;
                if (party.bride) partyHtml += `<p><strong>Bride:</strong> ${party.bride}</p>`;
                if (party.matron) partyHtml += `<p><strong>Matron of Honour:</strong> ${party.matron}</p>`;
                if (party.bestman) partyHtml += `<p><strong>Best Man:</strong> ${party.bestman}</p>`;
                if (party.bridalPairs && party.bridalPairs.length) {
                    party.bridalPairs.forEach((pair, index) => {
                        if (pair.person1 || pair.person2) {
                            partyHtml += `<p><strong>Bridal Pair ${index+1}:</strong> ${pair.person1 || '?'} & ${pair.person2 || '?'}</p>`;
                        }
                    });
                }
                if (party.flowerPairs && party.flowerPairs.length) {
                    party.flowerPairs.forEach((pair, index) => {
                        if (pair.person1 || pair.person2) {
                            partyHtml += `<p><strong>Flower Kids Pair ${index+1}:</strong> ${pair.person1 || '?'} & ${pair.person2 || '?'}</p>`;
                        }
                    });
                }
                if (party.parentsGroom) partyHtml += `<p><strong>Parents of Groom:</strong> ${party.parentsGroom}</p>`;
                if (party.parentsBride) partyHtml += `<p><strong>Parents of Bride:</strong> ${party.parentsBride}</p>`;
                if (party.otherPeople) partyHtml += `<p><strong>Other Important People:</strong> ${party.otherPeople}</p>`;
                document.getElementById('print-party').innerHTML = partyHtml || '<p>No data entered.</p>';

                let loveHtml = '';
                if (journal.howMet) loveHtml += `<p><strong>How They Met:</strong> ${journal.howMet}</p>`;
                if (journal.proposal) loveHtml += `<p><strong>The Proposal:</strong> ${journal.proposal}</p>`;
                if (journal.traditions) loveHtml += `<p><strong>Traditions:</strong> ${journal.traditions}</p>`;
                if (journal.firstDance) loveHtml += `<p><strong>First Dance:</strong> ${journal.firstDance}</p>`;
                if (journal.otherSongs) loveHtml += `<p><strong>Other Songs:</strong> ${journal.otherSongs}</p>`;
                if (journal.messages) loveHtml += `<p><strong>Messages:</strong> ${journal.messages}</p>`;
                if (journal.avoid) loveHtml += `<p><strong>Avoid:</strong> ${journal.avoid}</p>`;
                document.getElementById('print-love').innerHTML = loveHtml || '<p>No data entered.</p>';

                let venueHtml = '';
                if (journal.venueName) venueHtml += `<p><strong>Venue:</strong> ${journal.venueName}</p>`;
                if (journal.roomName) venueHtml += `<p><strong>Room:</strong> ${journal.roomName}</p>`;
                if (journal.weddingDate) venueHtml += `<p><strong>Date:</strong> ${journal.weddingDate}</p>`;
                if (journal.djName) venueHtml += `<p><strong>DJ:</strong> ${journal.djName}</p>`;
                if (journal.venueManager) venueHtml += `<p><strong>Venue Manager:</strong> ${journal.venueManager}</p>`;
                if (journal.caterer) venueHtml += `<p><strong>Caterer:</strong> ${journal.caterer}</p>`;
                if (journal.activities) venueHtml += `<p><strong>Activities:</strong> ${journal.activities}</p>`;
                document.getElementById('print-venue').innerHTML = venueHtml || '<p>No data entered.</p>';

                let logisticsHtml = '';
                if (journal.ceremonyTime) logisticsHtml += `<p><strong>Ceremony Start:</strong> ${journal.ceremonyTime}</p>`;
                if (journal.finishTime) logisticsHtml += `<p><strong>Finish Time:</strong> ${journal.finishTime}</p>`;
                if (journal.guestCount) logisticsHtml += `<p><strong>Guests:</strong> ${journal.guestCount}</p>`;
                if (journal.weddingScope) logisticsHtml += `<p><strong>Scope:</strong> ${journal.weddingScope}</p>`;
                if (journal.scopeOther) logisticsHtml += `<p><strong>Scope (other):</strong> ${journal.scopeOther}</p>`;
                if (journal.houseVisit) logisticsHtml += `<p><strong>House Visit:</strong> ${journal.houseVisit === 'yes' ? 'Yes' : 'No'}</p>`;
                if (journal.logisticsNotes) logisticsHtml += `<p><strong>Notes:</strong> ${journal.logisticsNotes}</p>`;
                document.getElementById('print-logistics').innerHTML = logisticsHtml || '<p>No data entered.</p>';

                // Set title language
                document.getElementById('print-title').innerText = currentLang === 'en' ? 'Master of Ceremonies' : 'Τελετάρχης';

                window.print();
            });

            // Initial load
            loadPartyData();
            loadJournalData();

            // Clear messages on input
            const partyInputs = document.querySelectorAll('#party-form input, #party-form textarea');
            partyInputs.forEach(input => {
                input.addEventListener('input', () => document.getElementById('party-saved-msg').innerText = '');
            });

            const journalInputs = document.querySelectorAll('#journal-form input, #journal-form textarea, #journal-form select');
            journalInputs.forEach(input => {
                input.addEventListener('input', () => document.getElementById('journal-saved-msg').innerText = '');
            });

            setLanguage('en');
        })();
    </script>

    <!-- Simple service worker for PWA (optional) -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('data:application/javascript,%23%20simple%20service%20worker%20for%20caching%0Aself.addEventListener%28%27install%27%2C%20e%20%3D%3E%20%7B%0A%20%20e.waitUntil%28%0A%20%20%20%20caches.open%28%27george-mc-v1%27%29.then%28cache%20%3D%3E%20cache.addAll%28%5B%27.%2F%27%5D%29%29%0A%20%20%29%3B%0A%7D%29%3B%0Aself.addEventListener%28%27fetch%27%2C%20e%20%3D%3E%20%7B%0A%20%20e.respondWith%28%0A%20%20%20%20caches.match%28e.request%29.then%28response%20%3D%3E%20response%20%7C%7C%20fetch%28e.request%29%29%0A%20%20%29%3B%0A%7D%29%3B').catch(err => console.log('SW registration failed', err));
            });
        }
    </script>
