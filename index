  <script>
    (function () {
      let currentLang = "en";

      const langEn = document.getElementById("lang-en");
      const langEl = document.getElementById("lang-el");

      const btnHome = document.getElementById("btn-home");
      const btnParty = document.getElementById("btn-party");
      const btnJournal = document.getElementById("btn-journal");

      const homeSection = document.getElementById("home-section");
      const partySection = document.getElementById("party-section");
      const journalSection = document.getElementById("journal-section");

      const bridalContainer = document.getElementById("bridal-pairs-container");
      const flowerContainer = document.getElementById("flower-pairs-container");

      function setLanguage(lang) {
        currentLang = lang;

        langEn.classList.toggle("active", lang === "en");
        langEl.classList.toggle("active", lang === "el");

        document.querySelectorAll("[data-en]").forEach((el) => {
          const text = el.getAttribute(`data-${lang}`);
          if (text) el.textContent = text;
        });
      }

      function showSection(section) {
        [homeSection, partySection, journalSection].forEach((s) => s.classList.remove("active"));
        section.classList.add("active");

        [btnHome, btnParty, btnJournal].forEach((b) => b.classList.remove("active"));
        if (section === homeSection) btnHome.classList.add("active");
        if (section === partySection) btnParty.classList.add("active");
        if (section === journalSection) btnJournal.classList.add("active");
      }

      function createBridalPair(person1 = "", person2 = "") {
        const div = document.createElement("div");
        div.className = "paired-row";
        div.innerHTML = `
          <div class="form-group">
            <label>Person 1</label>
            <input type="text" class="bridal-person1" value="${escapeHtml(person1)}" placeholder="Full name">
          </div>
          <div class="form-group">
            <label>Person 2</label>
            <input type="text" class="bridal-person2" value="${escapeHtml(person2)}" placeholder="Full name">
          </div>
        `;
        return div;
      }

      function createFlowerPair(person1 = "", person2 = "") {
        const div = document.createElement("div");
        div.className = "paired-row";
        div.innerHTML = `
          <div class="form-group">
            <label>Flower Kid 1</label>
            <input type="text" class="flower-person1" value="${escapeHtml(person1)}" placeholder="Full name">
          </div>
          <div class="form-group">
            <label>Flower Kid 2</label>
            <input type="text" class="flower-person2" value="${escapeHtml(person2)}" placeholder="Full name">
          </div>
        `;
        return div;
      }

      function loadBridalPairs(pairs) {
        bridalContainer.querySelectorAll(".paired-row").forEach((row) => row.remove());
        if (pairs && pairs.length) {
          pairs.forEach((p) => bridalContainer.appendChild(createBridalPair(p.person1, p.person2)));
        } else {
          bridalContainer.appendChild(createBridalPair());
        }
      }

      function loadFlowerPairs(pairs) {
        flowerContainer.querySelectorAll(".paired-row").forEach((row) => row.remove());
        if (pairs && pairs.length) {
          pairs.forEach((p) => flowerContainer.appendChild(createFlowerPair(p.person1, p.person2)));
        } else {
          flowerContainer.appendChild(createFlowerPair());
        }
      }

      function getBridalPairs() {
        return [...bridalContainer.querySelectorAll(".paired-row")].map((row) => ({
          person1: row.querySelector(".bridal-person1")?.value || "",
          person2: row.querySelector(".bridal-person2")?.value || ""
        }));
      }

      function getFlowerPairs() {
        return [...flowerContainer.querySelectorAll(".paired-row")].map((row) => ({
          person1: row.querySelector(".flower-person1")?.value || "",
          person2: row.querySelector(".flower-person2")?.value || ""
        }));
      }

      function loadPartyData() {
        const data = JSON.parse(localStorage.getItem("george_mc_party") || "{}");
        document.getElementById("groom").value = data.groom || "";
        document.getElementById("bride").value = data.bride || "";
        document.getElementById("matron").value = data.matron || "";
        document.getElementById("bestman").value = data.bestman || "";
        document.getElementById("parents-groom").value = data.parentsGroom || "";
        document.getElementById("parents-bride").value = data.parentsBride || "";
        document.getElementById("other-people").value = data.otherPeople || "";
        loadBridalPairs(data.bridalPairs || []);
        loadFlowerPairs(data.flowerPairs || []);
      }

      function loadJournalData() {
        const data = JSON.parse(localStorage.getItem("george_mc_journal") || "{}");
        document.getElementById("how-met").value = data.howMet || "";
        document.getElementById("proposal").value = data.proposal || "";
        document.getElementById("traditions").value = data.traditions || "";
        document.getElementById("first-dance").value = data.firstDance || "";
        document.getElementById("other-songs").value = data.otherSongs || "";
        document.getElementById("messages").value = data.messages || "";
        document.getElementById("avoid").value = data.avoid || "";
        document.getElementById("venue-name").value = data.venueName || "";
        document.getElementById("room-name").value = data.roomName || "";
        document.getElementById("wedding-date").value = data.weddingDate || "";
        document.getElementById("dj-name").value = data.djName || "";
        document.getElementById("venue-manager").value = data.venueManager || "";
        document.getElementById("caterer").value = data.caterer || "";
        document.getElementById("activities").value = data.activities || "";
        document.getElementById("ceremony-time").value = data.ceremonyTime || "";
        document.getElementById("finish-time").value = data.finishTime || "";
        document.getElementById("guest-count").value = data.guestCount || "";
        document.getElementById("wedding-scope").value = data.weddingScope || "";
        document.getElementById("scope-other").value = data.scopeOther || "";
        document.querySelector