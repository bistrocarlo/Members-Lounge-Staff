                        <!-- Pairs will be added here dynamically -->
                    </div>
                    <button type="button" class="btn-add" id="add-bridal-pair" data-en="+ Add Bridal Pair" data-el="+ Προσθήκη Ζευγαριού Παρέας">+ Add Bridal Pair</button>

                    <!-- Flower Kids Pairs -->
                    <div id="flower-pairs-container" style="margin-top: 2rem;">
                        <h3 style="color: #d4af37; margin: 1.5rem 0 1rem;" data-en="Flower Kids Pairs" data-el="Ζευγάρια Παιδιών με Λουλούδια">Flower Kids Pairs</h3>
