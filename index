<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
  <title>George Theodoropoulos · Master of Ceremonies</title>
  <meta name="description" content="Prestigious MC services by George Theodoropoulos. Warm, engaging, and impeccably professional. Bilingual: English & Greek." />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: #ffffff;
      color: #000000;
      font-family: 'Montserrat', sans-serif;
      font-weight: 400;
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    h1, h2, h3, h4 {
      font-family: 'Playfair Display', serif;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    h2 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid #d4af37;
      display: inline-block;
      padding-bottom: 0.25rem;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem;
      width: 100%;
      flex: 1;
    }

    .lang-switcher {
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
      margin: 1rem 0;
    }

    .lang-btn {
      background: transparent;
      border: 1px solid #d4af37;
      color: #000;
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 600;
      padding: 0.4rem 1.2rem;
      cursor: pointer;
      border-radius: 30px;
      transition: all 0.3s;
    }

    .lang-btn.active,
    .lang-btn:hover {
      background: #d4af37;
      color: #000;
      border-color: #d4af37;
    }

    .nav {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin: 2rem 0 1rem;
      flex-wrap: wrap;
    }

    .nav-btn {
      background: transparent;
      border: none;
      color: #000;
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 600;
      padding: 0.5rem 1.5rem;
      cursor: pointer;
      border-bottom: 3px solid transparent;
      transition: all 0.3s;
      letter-spacing: 1px;
    }

    .nav-btn.active {
      border-bottom-color: #d4af37;
      color: #d4af37;
    }

    .nav-btn:hover { color: #d4af37; }

    .section { display: none; animation: fade 0.3s ease; }
    .section.active { display: block; }

    @keyframes fade {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    .card {
      background: #f9f9f9;
      border: 1px solid #e0e0e0;
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }

    .service-item { margin-bottom: 1.5rem; }

    .service-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: #d4af37;
      margin-bottom: 0.25rem;
    }

    .price-tag {
      font-size: 2.5rem;
      font-weight: 700;
      color: #d4af37;
      font-family: 'Playfair Display', serif;
      line-height: 1.2;
    }

    .price-note {
      font-size: 1rem;
      color: #555;
      margin-top: 0.5rem;
    }

    .contact-info {
      background: #f9f9f9;
      padding: 2rem;
      border-radius: 12px;
      border-left: 6px solid #d4af37;
    }

    .contact-phone {
      font-size: 1.8rem;
      font-weight: 600;
      font-family: 'Playfair Display', serif;
      color: #000;
      text-decoration: none;
      display: inline-block;
      margin-bottom: 1rem;
    }

    .contact-phone:hover,
    .contact-email:hover { color: #d4af37; }

    .contact-email {
      color: #000;
      text-decoration: none;
      border-bottom: 1px solid #d4af37;
      font-weight: 500;
      font-size: 1.2rem;
      word-break: break-all;
    }

    .form-group { margin-bottom: 1.5rem; }

    label {
      display: block;
      font-family: 'Playfair Display', serif;
      font-weight: 600;
      color: #d4af37;
      margin-bottom: 0.5rem;
      font-size: 1.1rem;
    }

    input, textarea, select {
      width: 100%;
      padding: 1rem;
      background: #fff;
      border: 1px solid #ccc;
      color: #000;
      border-radius: 8px;
      font-family: 'Montserrat', sans-serif;
      font-size: 1rem;
      font-weight: 400;
      transition: border 0.3s;
    }

    input:focus, textarea:focus, select:focus {
      outline: none;
      border-color: #d4af37;
    }

    textarea {
      min-height: 100px;
      resize: vertical;
    }

    select {
      appearance: none;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='%23d4af37' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
      background-repeat: no-repeat;
      background-position: right 1rem center;
      background-size: 1.2rem;
    }

    .btn {
      background: #d4af37;
      color: #000;
      border: 1px solid #d4af37;
      padding: 1rem 2.5rem;
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      border-radius: 40px;
      cursor: pointer;
      transition: all 0.3s;
      margin-top: 1rem;
    }

    .btn:hover {
      background: transparent;
      color: #d4af37;
    }

    .btn-outline {
      background: transparent;
      color: #000;
      border: 1px solid #d4af37;
      margin-left: 1rem;
    }

    .btn-outline:hover {
      background: #d4af37;
      color: #000;
    }

    .btn-add {
      background: transparent;
      color: #d4af37;
      border: 1px dashed #d4af37;
      padding: 0.5rem 1rem;
      font-size: 1rem;
      border-radius: 30px;
      margin-bottom: 1rem;
      cursor: pointer;
    }

    .btn-add:hover {
      background: #d4af37;
      color: #000;
    }

    .footer {
      text-align: center;
      padding: 2rem 1rem;
      border-top: 1px solid #eee;
      margin-top: 3rem;
      color: #666;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .paired-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
      align-items: center;
    }

    .saved-msg {
      color: #d4af37;
      font-size: 0.9rem;
      margin-top: 0.5rem;
      text-align: right;
      font-style: italic;
    }

    .radio-group {
      display: flex;
      gap: 2rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .radio-option {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .radio-option input[type="radio"] {
      width: auto;
      accent-color: #d4af37;
    }

    #print-summary { display: none; }

    @media (max-width: 640px) {
      .grid-2, .grid-3, .paired-row {
        grid-template-columns: 1fr;
      }
      h2 { font-size: 1.6rem; }
      .nav-btn {
        font-size: 1rem;
        padding: 0.5rem 1rem;
      }
      .price-tag { font-size: 2rem; }
    }

    @media print {
      body { background: white; }
      .no-print, .nav, .lang-switcher, .btn, .footer, .nav-btn, .saved-msg {
        display: none !important;
      }
      .section { display: none !important; }
      #print-summary { display: block !important; }
      .card {
        border: 1px solid #d4af37;
        break-inside: avoid;
      }
      h2 {
        color: #000;
        border-bottom-color: #d4af37;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="lang-switcher no-print">
      <button class="lang-btn active" id="lang-en">EN</button>
      <button class="lang-btn" id="lang-el">EL</button>
    </div>

    <div style="text-align: center; margin: 0 0 1rem;">
      <h1 style="font-size: 2.5rem; letter-spacing: 2px;">GEORGE THEODOROPOULOS</h1>
      <p style="font-size: 1.2rem; color: #d4af37; font-family: 'Playfair Display'; font-weight: 600;"
         id="mc-title"
         data-en="Master of Ceremonies"
         data-el="Τελετάρχης">Master of Ceremonies</p>
    </div>

    <div class="nav no-print">
      <button class="nav-btn active" id="btn-home" data-en="Home" data-el="Αρχική">Home</button>
      <button class="nav-btn" id="btn-party" data-en="Wedding Party" data-el="Γαμήλια Παρέα">Wedding Party</button>
      <button class="nav-btn" id="btn-journal" data-en="Event Journal" data-el="Ημερολόγιο Εκδήλωσης">Event Journal</button>
    </div>

    <div class="no-print" style="text-align: right; margin-bottom: 1rem;">
      <button class="btn btn-outline" id="print-btn" data-en="Print Summary (PDF)" data-el="Εκτύπωση Περίληψης (PDF)">Print Summary (PDF)</button>
    </div>

    <section id="home-section" class="section active">
      <div class="card">
        <h2 data-en="About" data-el="Σχετικά">About</h2>
        <p
          data-en="Warm, confident, and impeccably professional — George ensures your celebration is seamless and heartfelt without ever overshadowing your special moments. With years of experience and a dedication to personalisation, he becomes the calm, charismatic thread that weaves your event together. Fully bilingual: fluent in English and Greek, offering seamless MC services in both languages."
          data-el="Ζεστός, σίγουρος και άψογα επαγγελματίας — ο George εξασφαλίζει ότι η γιορτή σας είναι άψογη και εγκάρδια χωρίς ποτέ να επισκιάζει τις ξεχωριστές σας στιγμές. Με χρόνια εμπειρίας και αφοσίωση στην εξατομίκευση, γίνεται η ήρεμη, χαρισματική παρουσία που δένει την εκδήλωσή σας. Απόλυτα δίγλωσσος: άπταιστα Αγγλικά και Ελληνικά, προσφέροντας άψογες υπηρεσίες τελετάρχη και στις δύο γλώσσες."
        >
          Warm, confident, and impeccably professional — George ensures your celebration is seamless and heartfelt without ever overshadowing your special moments. With years of experience and a dedication to personalisation, he becomes the calm, charismatic thread that weaves your event together. Fully bilingual: fluent in English and Greek, offering seamless MC services in both languages.
        </p>
      </div>

      <div class="card">
        <h2 data-en="Services" data-el="Υπηρεσίες">Services</h2>

        <div class="service-item">
          <div class="service-title" data-en="Bilingual MC (English & Greek)" data-el="Δίγλωσσος Τελετάρχης (Αγγλικά & Ελληνικά)">Bilingual MC (English & Greek)</div>
          <p data-en="Seamlessly host your event in both English and Greek, ensuring all guests feel included and engaged." data-el="Φιλοξενήστε άψογα την εκδήλωσή σας στα Αγγλικά και στα Ελληνικά, διασφαλίζοντας ότι όλοι οι καλεσμένοι αισθάνονται ότι συμμετέχουν.">Seamlessly host your event in both English and Greek, ensuring all guests feel included and engaged.</p>
        </div>

        <div class="service-item">
          <div class="service-title" data-en="Pre-Event Planning" data-el="Προγραμματισμός">Pre-Event Planning</div>
          <p data-en="Face-to-face or Zoom meetings to understand your vision, prepare the run sheet, and align with venue food timelines." data-el="Συναντήσεις διά ζώσης ή μέσω Zoom για να κατανοήσουμε το όραμά σας, να προετοιμάσουμε το χρονοδιάγραμμα και να ευθυγραμμιστούμε με τα ωράρια φαγητού του χώρου.">Face-to-face or Zoom meetings to understand your vision, prepare the run sheet, and align with venue food timelines.</p>
        </div>

        <div class="service-item">
          <div class="service-title" data-en="Vendor Liaison" data-el="Συντονισμός Προμηθευτών">Vendor Liaison</div>
          <p data-en="Arrive early to connect with Function Manager, Photographer, DJ/Band — ensuring everyone is perfectly synced." data-el="Φτάνω νωρίς για να συνδεθώ με τον Υπεύθυνο Εκδήλωσης, τον Φωτογράφο, τον DJ/Μπάντα — διασφαλίζοντας ότι όλοι είναι απόλυτα συντονισμένοι.">Arrive early to connect with Function Manager, Photographer, DJ/Band — ensuring everyone is perfectly synced.</p>
        </div>

        <div class="service-item">
          <div class="service-title" data-en="Professional Audio" data-el="Επαγγελματικός Ήχος">Professional Audio</div>
          <p data-en="High-quality wireless microphone, seamlessly connected to house system or DJ equipment." data-el="Υψηλής ποιότητας ασύρματο μικρόφωνο, άψογα συνδεδεμένο με το σύστημα ήχου του χώρου ή του DJ.">High-quality wireless microphone, seamlessly connected to house system or DJ equipment.</p>
        </div>

        <div class="service-item">
          <div class="service-title" data-en="Warm Engagement" data-el="Ζεστή Παρουσία">Warm Engagement</div>
          <p data-en="Energetic, polished presence that keeps the night flowing without making it 'all about the MC.'" data-el="Ενεργητική, κομψή παρουσία που διατηρεί τη ροή της βραδιάς χωρίς να την κάνει 'όλη για τον MC'.">Energetic, polished presence that keeps the night flowing without making it 'all about the MC.'</p>
        </div>
      </div>

      <div class="card">
        <h2 data-en="Pricing" data-el="Τιμολόγηση">Pricing</h2>
        <div class="price-tag" data-en="Packages start from $1,650 AUD" data-el="Πακέτα από $1,650 AUD">Packages start from $1,650 AUD</div>
        <div class="price-note" data-en="per night · base rate" data-el="ανά βραδιά · βασική τιμή">per night · base rate</div>
        <p style="margin-top: 1.5rem; color: #555;" data-en="Variables affecting price: parking, travel, extended hours, additional responsibilities." data-el="Παράγοντες που επηρεάζουν την τιμή: πάρκινγκ, ταξίδι, παρατεταμένες ώρες, επιπλέον ευθύνες.">Variables affecting price: parking, travel, extended hours, additional responsibilities.</p>
      </div>

      <div class="contact-info">
        <h2 style="border-bottom: none; display: block;" data-en="Contact" data-el="Επικοινωνία">Contact</h2>
        <a href="tel:+61418817976" class="contact-phone">+61 418 817 976</a><br />
        <span style="color: #d4af37; font-weight: 600;" data-en="email" data-el="email">email</span>
        <a href="mailto:George.Theodoropoulos31@gmail.com" class="contact-email">George.Theodoropoulos31@gmail.com</a>
        <p style="margin-top: 1.5rem;" data-en="Available for meetings with venue managers — let's create something unforgettable." data-el="Διαθέσιμος για συναντήσεις με υπεύθυνους χώρων — ας δημιουργήσουμε κάτι αξέχαστο.">Available for meetings with venue managers — let's create something unforgettable.</p>
      </div>
    </section>

    <section id="party-section" class="section">
      <div class="card">
        <h2 data-en="Wedding Party Details" data-el="Λεπτομέρειες Γαμήλιας Παρέας">Wedding Party Details</h2>
        <p data-en="Add pairs for the bridal party and for flower kids." data-el="Προσθέστε ζευγάρια για τη γαμήλια παρέα και για τα παιδιά με λουλούδια.">Add pairs for the bridal party and for flower kids.</p>

        <form id="party-form">
          <div class="grid-2">
            <div class="form-group">
              <label data-en="Groom's Full Name" data-el="Ονοματεπώνυμο Γαμπρού">Groom's Full Name</label>
              <input type="text" id="groom" placeholder="e.g. James Michael Smith" />
            </div>
            <div class="form-group">
              <label data-en="Bride's Full Name" data-el="Ονοματεπώνυμο Νύφης">Bride's Full Name</label>
              <input type="text" id="bride" placeholder="e.g. Emma Rose Johnson" />
            </div>
          </div>

          <div class="grid-2">
            <div class="form-group">
              <label data-en="Matron of Honour" data-el="Κουμπάρα">Matron of Honour</label>
              <input type="text" id="matron" placeholder="Full name" />
            </div>
            <div class="form-group">
              <label data-en="Best Man" data-el="Κουμπάρος">Best Man</label>
              <input type="text" id="bestman" placeholder="Full name" />
            </div>
          </div>

          <div id="bridal-pairs-container">
            <h3 style="color: #d4af37; margin: 1.5rem 0 1rem;" data-en="Bridal Party Pairs" data-el="Ζευγάρια Γαμήλιας Παρέας">Bridal Party Pairs</h3>
          </div>
          <button type="button" class="btn-add no-print" id="add-bridal-pair" data-en="+ Add Bridal Pair" data-el="+ Προσθήκη Ζευγαριού Παρέας">+ Add Bridal Pair</button>

          <div id="flower-pairs-container" style="margin-top: 2rem;">
            <h3 style="color: #d4af37; margin: 1.5rem 0 1rem;" data-en="Flower Kids Pairs" data-el="Ζευγάρια Παιδιών με Λουλούδια">Flower Kids Pairs</h3>
          </div>
          <button type="button" class="btn-add no-print" id="add-flower-pair" data-en="+ Add Flower Kids Pair" data-el="+ Προσθήκη Ζευγαριού Παιδιών">+ Add Flower Kids Pair</button>

          <div class="grid-2" style="margin-top: 2rem;">
            <div class="form-group">
              <label data-en="Parents of Groom" data-el="Γονείς Γαμπρού">Parents of Groom</label>
              <input type="text" id="parents-groom" placeholder="e.g. John & Mary Smith" />
            </div>
            <div class="form-group">
              <label data-en="Parents of Bride" data-el="Γονείς Νύφης">Parents of Bride</label>
              <input type="text" id="parents-bride" placeholder="e.g. Robert & Linda Johnson" />
            </div>
          </div>

          <div class="form-group">
            <label data-en="Other important people (grandparents, special friends, etc.)" data-el="Άλλα σημαντικά άτομα (παππούδες, ιδιαίτεροι φίλοι, κλπ.)">Other important people (grandparents, special friends, etc.)</label>
            <textarea id="other-people" placeholder="Names and relationships"></textarea>
          </div>

          <button type="button" class="btn no-print" id="save-party" data-en="Save Wedding Party" data-el="Αποθήκευση Γαμήλιας Παρέας">Save Wedding Party</button>
          <div id="party-saved-msg" class="saved-msg"></div>
        </form>
      </div>
    </section>

    <section id="journal-section" class="section">
      <div class="card">
        <h2 data-en="Love Story & Journal" data-el="Ιστορία Αγάπης & Ημερολόγιο">Love Story & Journal</h2>
        <p data-en="Share the beautiful details that will help George weave your unique story into the evening." data-el="Μοιραστείτε τις όμορφες λεπτομέρειες που θα βοηθήσουν τον George να υφάνει τη μοναδική σας ιστορία στη βραδιά.">Share the beautiful details that will help George weave your unique story into the evening.</p>

        <form id="journal-form">
          <div class="form-group">
            <label data-en="How They Met" data-el="Πώς Γνωρίστηκαν">How They Met</label>
            <textarea id="how-met" placeholder="Describe the first meeting, early days..."></textarea>
          </div>

          <div class="form-group">
            <label data-en="The Proposal" data-el="Η Πρόταση Γάμου">The Proposal</label>
            <textarea id="proposal" placeholder="How, when, where? Any special details?"></textarea>
          </div>

          <div class="form-group">
            <label data-en="Family Traditions / Cultural Elements" data-el="Οικογενειακές Παραδόσεις / Πολιτιστικά Στοιχεία">Family Traditions / Cultural Elements</label>
            <textarea id="traditions" placeholder="Any customs, rituals, or family traditions to acknowledge?"></textarea>
          </div>

          <div class="grid-2">
            <div class="form-group">
              <label data-en="First Dance Song" data-el="Τραγούδι Πρώτου Χορού">First Dance Song</label>
              <input type="text" id="first-dance" placeholder="Song title & artist" />
            </div>
            <div class="form-group">
              <label data-en="Other Special Songs" data-el="Άλλα Ιδιαίτερα Τραγούδια">Other Special Songs</label>
              <input type="text" id="other-songs" placeholder="e.g. parent dances, processional" />
            </div>
          </div>

          <div class="form-group">
            <label data-en="Special Messages to Guests" data-el="Ιδιαίτερα Μηνύματα στους Καλεσμένους">Special Messages to Guests</label>
            <textarea id="messages" placeholder="Anything you'd like George to convey to your guests?"></textarea>
          </div>

          <div class="form-group">
            <label data-en="Sensitive Topics / Things to Avoid" data-el="Ευαίσθητα Θέματα / Τι να Αποφευχθεί">Sensitive Topics / Things to Avoid</label>
            <textarea id="avoid" placeholder="e.g. certain jokes, exclusions, etc."></textarea>
          </div>

          <div style="margin-top: 3rem; border-top: 2px solid #d4af37; padding-top: 2rem;">
            <h2 style="border-bottom: none;" data-en="Venue & Team" data-el="Χώρος & Ομάδα">Venue & Team</h2>
            <p data-en="Key contacts and venue details." data-el="Σημαντικές επαφές και λεπτομέρειες χώρου.">Key contacts and venue details.</p>

            <div class="grid-2">
              <div class="form-group">
                <label data-en="Venue Name" data-el="Όνομα Χώρου">Venue Name</label>
                <input type="text" id="venue-name" placeholder="e.g. The Great Hall" />
              </div>
              <div class="form-group">
                <label data-en="Room Name" data-el="Όνομα Αίθουσας">Room Name</label>
                <input type="text" id="room-name" placeholder="e.g. Ballroom, Garden Terrace" />
              </div>
            </div>

            <div class="grid-2">
              <div class="form-group">
                <label data-en="Wedding Date" data-el="Ημερομηνία Γάμου">Wedding Date</label>
                <input type="date" id="wedding-date" />
              </div>
              <div class="form-group">
                <label data-en="DJ Name" data-el="Όνομα DJ">DJ Name</label>
